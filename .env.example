GOOGLE_API_KEY=your_google_api_key_here
GEMINI_API_KEY=your_gemini_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# --- Vendored legacy pipelines (in-process) ---
# Pomodoro (geometri) ve agentic (Türkçe) modülleri repo içine vendor edildi.
# Örnek YAML setleri repoda; ağır PDF içerikleri (MEB kitapları, data klasörü)
# .gitignore'da — production'da volume mount.
#
# Aşağıdaki path'lerin DEFAULT'ları repo köküne göre relative; sadece dış mount
# kullanmak istiyorsan override et.

# Geometri — örnek YAML kütüphanesi (default: <repo>/ortak)
# LEGACY_GEO_YAML_DIR=/abs/path/to/ortak

# Türkçe (agentic) — örnek config + template + konular dizinleri (default: <repo>/...)
# LEGACY_TURKCE_CONFIGS_DIR=/abs/path/to/configs
# LEGACY_TURKCE_TEMPLATES_DIR=/abs/path/to/templates
# LEGACY_TURKCE_KONULAR_DIR=/abs/path/to/konular

# Türkçe pipeline'ın MEB ders kitapları (~633 MB PDF) — repo dışı, volume mount.
# LEGACY_TURKCE_MEB_BOOKS_DIR=/abs/path/to/meb_books

# Türkçe pipeline'ın referans data klasörü (~47 MB PDF) — repo dışı, volume mount.
# LEGACY_TURKCE_DATA_DIR=/abs/path/to/data

# Pipeline state dosyaları (default: <repo>/.legacy_state)
# LEGACY_STATE_DIR=/abs/path/to/.legacy_state

# Kullanıcının UI'dan upload ettiği YAML'ların yazıldığı dizin (default: <repo>/.legacy_uploads)
# LEGACY_UPLOADS_DIR=/abs/path/to/.legacy_uploads

# Pipeline subprocess yerine in-process çalışır; timeout her run için.
LEGACY_TIMEOUT_SECONDS=1800

# --- Authentication ---
# Token yaşam süresi saat olarak (0 = sonsuz). Default: 168 (7 gün).
# AUTH_TOKEN_TTL_HOURS=168

# Yeni kayıt minimum şifre uzunluğu. Default: 8.
# PASSWORD_MIN_LENGTH=8

# Open self-signup'ı kapatmak için 'false' yap. Default: true.
# SIGNUP_ENABLED=true

# Opsiyonel: ilk admin kullanıcı seed. Set ise ve kullanıcı yoksa yaratılır.
# ADMIN_EMAIL=admin@example.com
# ADMIN_PASSWORD=change_me_strong_password

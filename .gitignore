# Vendored legacy pipelines — küçük örnek setler repoda; ağır binary'ler mount edilir.
# Repoda örnek olarak küçük subset'ler tutuluyor (backend/legacy_app/ altında):
#   - backend/legacy_app/geometri/ortak/, backend/legacy_app/kadir_hoca/{configs,templates,konular}/
# Bunları .gitignore ETME.
# Mount via env: meb_books/ (~633MB PDF), data/ (~47MB PDF) ve büyük PDF/PNG asset'ler.
backend/meb_books/
backend/data/
# Templates klasöründeki büyük binary'ler (PDF/PNG/JPG); YAML'lar repoda kalır.
backend/legacy_app/kadir_hoca/templates/**/*.pdf
backend/legacy_app/kadir_hoca/templates/**/*.png
backend/legacy_app/kadir_hoca/templates/**/*.jpg
backend/legacy_app/kadir_hoca/templates/**/*.jpeg
# Konular klasöründeki büyük asset'ler
